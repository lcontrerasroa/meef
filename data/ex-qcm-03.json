    {
      "id": 2,
      "prompt": "Comment se prononce &lt;a&gt; dans <em>cl<u>a</u>ss</em> ? (SR5)",
      "options": ["/æ/", "/ɑː/", "/eɪ/", "/ɑ/"],
      "answer": 1,
      "feedback": "Sous-règle 5 : &lt;a&gt; devant /s/ (+ consonne ou fin de mot) → /ɑː/. <em>class</em> /klɑːs/."
